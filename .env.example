# Secwatcher environment variables
# Copy to .env for local development. In CI, set these as GitHub Actions secrets.

# GitHub App credentials
# Create the App at https://github.com/settings/apps with the scopes listed in README.md
REPOSENTRY_APP_ID=
REPOSENTRY_INSTALLATION_ID=

# Private key contents (PEM). Multi-line value, paste between quotes for local dev.
# In Actions, store the raw PEM as a secret and reference directly.
REPOSENTRY_APP_PRIVATE_KEY=

# Slack Incoming Webhook URL for alert delivery
REPOSENTRY_SLACK_WEBHOOK=

# Optional: override owner/org being scanned (defaults to App installation account)
# REPOSENTRY_OWNER=cyrillical00
